;; patterns-and-edits.nexus — pattern, bind, mutate, retract,
;; validate, subscribe, constrain, atomic batch. Uses the
;; flow-graph schema for continuity.

;; ──────────────── Bind aliasing ────────────────
;; `@a=@b` aliases two positions; matches if they unify. Useful
;; for self-edges (Edge whose `from` equals its `to`):

(| Edge @from=@to @kind |)

;; ──────────────── Wildcard ────────────────
;; `_` matches anything at that position without binding.
;; Find every Edge of any kind, ignore from / to.

(| Edge _ _ @kind |)

;; ──────────────── Negate ────────────────
;; `!` inside a pattern negates a constraint. Find Nodes whose
;; name is NOT "criome daemon":

(| Node !"criome daemon" |)

;; Top-level retract — `!Record` removes the asserted fact:
;; (uncomment to actually retract)
;; !(Node User)

;; ──────────────── Mutate ────────────────
;; `~` replaces an existing record with the new content. The
;; identity (slot) is preserved; this is a whole-record swap.

~(Node "criome daemon — validator + sema")

;; Mutate-with-pattern: keep from + to, change every matching
;; Edge's kind to Flow.

~(| Edge @from @to _ |) (Edge @from @to Flow)

;; ──────────────── Validate (dry-run) ────────────────
;; `?` prefix on any verb turns it into a dry-run. Tells you
;; whether the assert would succeed without doing it.

?(Node "Fresh node")
?~(Node "would replace this node's name")

;; ──────────────── Subscribe ────────────────
;; `*` opens a continuous query on this connection. Events stream
;; from now onward — there is NO initial snapshot. If the client
;; wants current state, it issues a separate Query first. One
;; subscription per connection; close the socket to end.

*(| Node @name |)

;; ──────────────── Constrain (conjunction) ────────────────
;; `{| ... |}` is logical AND across patterns. Shared bind
;; names unify. Find every Edge of kind DependsOn whose `to`
;; Node has a known name:

{|
  (| Edge @from @to DependsOn |)
  (| Node  @to-name |)
|}

;; Projection over a join:

{|
  (| Edge @from @to @kind |)
  (| Node @to-name |)
|} { from to to-name kind }

;; ──────────────── Atomic batch ────────────────
;; `[| ... |]` runs multiple edits all-or-nothing. Each item
;; carries its own verb sigil. Useful when invariants span
;; multiple records. Edges within the batch reference the
;; preceding Nodes by their assigned slots (criome assigns slots
;; in order; for M0 the client must round-trip if it needs the
;; assigned slots back to compose later edges).

[|
  (Node Apple)
  (Node Banana)
  (Edge 200 201 DependsOn)
|]
