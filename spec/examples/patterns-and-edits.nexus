;; patterns-and-edits.nexus
;;
;; Tier 0 examples for bind, wildcard, mutate, retract, validate,
;; subscribe, constrain, and atomic requests.

;; Bind positions are typed records.

(Match (EdgeQuery (Bind) (Bind) (Bind)) Any)

;; Wildcard matches without binding.

(Match (EdgeQuery (Wildcard) (Wildcard) (Bind)) Any)

;; Concrete field matching.

(Match (NodeQuery "criome daemon") Any)

;; Whole-record replacement at a slot.

(Mutate 102 (Node "criome daemon - validator and sema"))

;; Retract by kind and slot.

(Retract Node 102)

;; Validate is a dry-run wrapper over another request.

(Validate (Assert (Node "Fresh node")))
(Validate (Mutate 102 (Node "would replace this node's name")))

;; Subscribe opens a continuous match on the connection.

(Subscribe (NodeQuery (Bind)) ImmediateExtension Block)

;; Constrain composes multiple patterns and names the bind set that must unify.

(Constrain
  [(EdgeQuery (Bind) (Bind) DependsOn)
   (NodeQuery (Bind))]
  (Unify [to])
  Any)

;; Projection selects fields from a matched shape.

(Project (EdgeQuery (Bind) (Bind) (Bind)) (Fields [from to kind]) Any)

;; Atomic bundles requests as all-or-nothing state change.

(Atomic [(Assert (Node Apple))
         (Assert (Node Banana))
         (Assert (Edge 200 201 DependsOn))])
