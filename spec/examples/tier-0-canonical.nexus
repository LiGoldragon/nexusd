;; tier-0-canonical.nexus
;;
;; Canonical Nexus Tier 0 examples.
;;
;; Tier 0 is typed text over records and sequences. Every top-level
;; request has an explicit verb record. Patterns are decoded by the
;; receiving schema type; there is no separate pattern delimiter.

;; ------------------------------------------------------------------
;; State-changing requests
;; ------------------------------------------------------------------

(Assert (Node User))
(Assert (Node "nexus daemon"))
(Assert (Edge 100 101 Flow))

(Mutate 100 (Node "renamed node"))
(Retract Node 100)

(Atomic [(Assert (Node A))
         (Assert (Node B))
         (Mutate 100 (Node C))])

;; ------------------------------------------------------------------
;; Read requests
;; ------------------------------------------------------------------

(Match (NodeQuery (Bind)) Any)
(Match (EdgeQuery (Bind) (Bind) (Bind)) Any)
(Match (EdgeQuery 100 (Bind) Flow) (Limit 10))

(Subscribe (NodeQuery (Bind)) ImmediateExtension Block)
(Validate (Assert (Node "dry run")))

;; ------------------------------------------------------------------
;; Read-plan payloads
;; ------------------------------------------------------------------

(Match (Aggregate (NodeQuery (Bind)) Count) Any)
(Match (Project (NodeQuery (Bind)) (Fields [name])) Any)

(Match
  (Constrain
    [(EdgeQuery 100 (Bind) Flow)
     (NodeQuery (Bind))]
    (Unify [to]))
  Any)

(Match (Infer (NodeQuery (Bind)) StandardOntology) Any)
(Match
  (Recurse (NodeQuery (Bind)) (EdgeQuery (Bind) (Bind) DependsOn) Fixpoint)
  Any)

;; ------------------------------------------------------------------
;; Replies
;; ------------------------------------------------------------------

(Ok)
(Diagnostic Error E0099 "Mutate is outside the current daemon scope")

[(Node User)
 (Node "nexus daemon")]

[(SlotBinding 1024 (Node User))
 (SlotBinding 1025 (Node "nexus daemon"))]
