;; queries.nexus — pattern matching + operators + projection in
;; actual nexus syntax.
;;
;; A query is a pattern `(| KindName … |)` followed by zero or
;; more operator records (Pascal-named, applied left-to-right),
;; optionally terminated by a projection shape `{ … }`.
;;
;; Patterns use 1-pipe parens for the abstraction level. Bind
;; variables `@x` capture matched values and unify across
;; positions (datalog-style non-linear binds).

;; ──────────────── Bare pattern (top-level query) ────────────────
;; Find the KindDecl whose :name field is "KindDecl". Returns
;; matched records. At top-level, a pattern is implicitly a Query.

(| KindDecl :name "KindDecl" |)

;; ──────────────── Bind + projection ────────────────
;; Capture the matched record's slot, return only its name.

(| KindDecl @kind :name "KindDecl" |) { @kind }

;; ──────────────── Conjunction (datalog join) ────────────────
;; Multiple patterns joined by shared bind names. Find every Fn
;; whose :module references a public Module.

{|
  (| Fn @fn :module @mod |)
  (| Module @mod :visibility Public |)
|} { @fn @mod }

;; ──────────────── Negation ────────────────
;; `!` inside a pattern negates a constraint. Find Modules that
;; do NOT have :visibility Public.

(| Module @mod !:visibility Public |) { @mod }

;; ──────────────── Optional / left-join ────────────────
;; `(|| … ||)` is left-join: succeeds with None if no match.
;; Find every Fn; include its parent Module if known, else None.

{|
  (| Fn @fn :name @fname |)
  (|| Module @mod :members [@fn] ||)
|} { @fn @fname @mod }

;; ──────────────── Aggregation operator ────────────────
;; Operators are Pascal-named records, applied by juxtaposition
;; after the pattern. (Count) returns the match count.

(| Person |) (Count)

;; (Sum @v) sums the bind across matches:
(| Sale @v :customer @c |) (GroupBy @c (Sum @v)) { @c (Sum @v) }

;; ──────────────── Pagination ────────────────

(| Person @p :age @a |) (OrderBy [(@a Desc)]) (Limit 10) { @p @a }

;; ──────────────── Subscription ────────────────
;; `<| … |>` opens a subscription. criomed streams diffs as the
;; pattern's match-set changes.

<| (| Order @id :status Pending |) (Limit 100) |>
