;; flow-graph.nexus
;;
;; Explicit Tier 0 request records for a small flow graph.
;;
;; Schema sketch:
;;   Node  { name: String }
;;   Edge  { from: Slot<Node>, to: Slot<Node>, kind: RelationKind }
;;   Graph { title: String, nodes: Vec<Slot<Node>>, edges: Vec<Slot<Edge>>, subgraphs: Vec<Slot<Graph>> }

;; Nodes

(Assert (Node User))
(Assert (Node "nexus daemon"))
(Assert (Node "criome daemon"))
(Assert (Node "forge daemon"))
(Assert (Node "sema redb store"))

;; Edges

(Assert (Edge 100 101 Flow))
(Assert (Edge 101 102 Flow))
(Assert (Edge 102 104 Produces))
(Assert (Edge 102 103 DependsOn))

;; Graph

(Assert
  (Graph "criome request flow"
         [100 101 102 103 104]
         [200 201 202 203]
         []))

;; Matches

(Match (NodeQuery (Bind)) Any)
(Match (EdgeQuery 102 (Bind) (Bind)) Any)
(Match (EdgeQuery (Bind) (Bind) DependsOn) Any)
(Match (GraphQuery "criome request flow" (Bind) (Bind) (Bind)) Any)

;; Projection read plan

(Match (Project (NodeQuery (Bind)) (Fields [name])) Any)
