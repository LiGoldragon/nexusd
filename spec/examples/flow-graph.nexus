;; flow-graph.nexus — designing architecture in sema as a
;; flow-graph. The first criomed-handled record category per Li
;; 2026-04-25.
;;
;; Three kinds: Node (shape + label), Edge (typed arrow with
;; optional label), Graph (titled container of nodes + edges +
;; nested subgraphs).
;;
;; This is what Mermaid does, but in fully-typed binary records
;; criomed validates and stores. Each Assert below is a real
;; signal frame.

;; ──────────────── A small architecture diagram ────────────────

;; The three nodes:
(Assert (Node :slot 100
              :id "user"
              :label "User"
              :shape Round))

(Assert (Node :slot 101
              :id "nexus"
              :label "nexus daemon\n(text → signal)"
              :shape Rect))

(Assert (Node :slot 102
              :id "criome"
              :label "criome daemon\n(validator + sema)"
              :shape Rect))

(Assert (Node :slot 103
              :id "lojix"
              :label "lojix daemon\n(forge + store)"
              :shape Rect))

(Assert (Node :slot 104
              :id "sema"
              :label "sema (redb)"
              :shape Cylinder))

;; The edges:
(Assert (Edge :slot 200
              :from 100
              :to 101
              :label "nexus text"
              :style Solid))

(Assert (Edge :slot 201
              :from 101
              :to 102
              :label "signal rkyv"
              :style Solid))

(Assert (Edge :slot 202
              :from 102
              :to 104
              :label "writes"
              :style Thick))

(Assert (Edge :slot 203
              :from 102
              :to 103
              :label "lojix-schema"
              :style Solid))

;; The graph that ties them together:
(Assert (Graph :slot 300
               :title "criome request flow"
               :direction LeftRight
               :nodes [100 101 102 103 104]
               :edges [200 201 202 203]
               :subgraphs []))

;; ──────────────── Querying the flow-graph back ────────────────

;; All nodes in the diagram:
(| Node @n |) { @n }

;; Edges leaving the criome daemon:
(| Edge @e :from 102 |) { @e }

;; The whole graph by title:
(| Graph @g :title "criome request flow" |) { @g }
