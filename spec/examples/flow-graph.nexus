;; flow-graph.nexus — assert + query a small flow-graph using
;; signal's first-milestone kinds (Node, Edge, Graph).
;;
;; Per Li 2026-04-26: nexus is the text equivalent of reading a
;; known-type binary format. Records are positional, no field
;; names appear in the text, no Assert wrapper. The reader/writer
;; must know the schema to interpret each record.
;;
;; Schema (signal/src/flow.rs):
;;   Node  { id: String, label: String }
;;   Edge  { from: Slot, to: Slot, kind: RelationKind }
;;   Graph { title: String, nodes: Vec<Slot>, edges: Vec<Slot>, subgraphs: Vec<Slot> }
;;
;; RelationKind is a closed enum: Flow / DependsOn / Contains /
;; References / Produces / Consumes / Calls / Implements / IsA.
;;
;; A bare record at top level IS an assertion. Slots (u64) are
;; bare integers. Strings: bare ident-class tokens (camelCase /
;; kebab-case) emit bare; anything else uses "..." or """...""".
;; Unit variants (RelationKind, Option's None, etc.) emit bare.

;; ──────────────── Five Nodes ────────────────

(Node user   User)
(Node nexus  "nexus daemon")
(Node criome "criome daemon")
(Node lojix  "lojix daemon")
(Node sema   "sema redb store")

;; ──────────────── Four Edges ────────────────
;; Slots above were assigned 100..104 by criome at write time;
;; we reference them as bare integers here. Each Edge picks one
;; RelationKind variant — bare PascalCase.

(Edge 100 101 Flow)        ;; user → nexus: data flows
(Edge 101 102 Flow)        ;; nexus → criome: data flows
(Edge 102 104 Produces)    ;; criome → sema: criome produces sema records
(Edge 102 103 DependsOn)   ;; criome → lojix: criome depends on lojix's services

;; ──────────────── The Graph ────────────────

(Graph "criome request flow"
       [100 101 102 103 104]
       [200 201 202 203]
       [])

;; ──────────────── Queries ────────────────

;; All Nodes; bind id and label by schema-position.
(| Node @id @label |)

;; Edges leaving slot 102 (criome). The bound `to` and `kind`
;; come back; the literal 102 anchors `from`.
(| Edge 102 @to @kind |)

;; All edges of a specific kind.
(| Edge @from @to DependsOn |)

;; The Graph by title — quoted-string in pattern position
;; matches that exact value.
(| Graph "criome request flow" @nodes @edges @subgraphs |)

;; ──────────────── Projection ────────────────

;; Project just the `label` field of each Node.
(| Node @id @label |) { label }
